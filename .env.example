# Runtime mode: development | staging | production
APP_ENV=development

# API base url used by production adapter layer.
API_BASE_URL=https://api.homefinder.example.com

# Request timeout in milliseconds.
API_TIMEOUT_MS=5000

# Number of retries for transient network/timeout failures.
API_RETRY_COUNT=1

# Delay between retries in milliseconds (incremental backoff base).
API_RETRY_DELAY_MS=100

# true = use in-memory/mock services, false = use HTTP gateways
USE_MOCK_API=true

# Optional analytics transport (leave empty to keep local in-memory tracking)
ANALYTICS_ENDPOINT=
ANALYTICS_WRITE_KEY=
ANALYTICS_TIMEOUT_MS=3000

# Secret used to derive AES key for token storage encryption at rest
TOKEN_ENCRYPTION_KEY=change-me-in-production

# Contact flow anti-spam guard (client-side)
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_MAX_REQUESTS=3

# Optional crash/error monitoring
SENTRY_DSN=
SENTRY_RELEASE=0.1.0

# Staging smoke integration check
STAGING_SMOKE_ENABLED=false
STAGING_API_BASE_URL=
STAGING_SMOKE_TIMEOUT_MS=5000

# KPI alert thresholds
KPI_MIN_SEARCH_TO_DETAIL=85
KPI_MIN_DETAIL_TO_SAVE=8
KPI_MIN_DETAIL_TO_CONTACT=3
